{
  "name": "jwtbackend",
  "version": "1.0.0",
  "description": "JWT NodeJS React",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./src/public/css/style.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./src/public/css/style.css --watch",
    "start": "concurrently \"npm run watch:css\" \"nodemon --exec babel-node src/server.js\""
  },
  "author": "XimenT",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "bcryptjs": "^3.0.3",
    "body-parser": "2.2.2",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "ejs": "6.0.1",
    "express": "5.2.1",
    "jsonwebtoken": "9.0.3",
    "mysql2": "3.22.4",
    "nodemon": "3.1.14",
    "react-toastify": "11.1.0",
    "sequelize": "6.37.8",
    "sequelize-cli": "6.6.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^10.0.0",
    "tailwindcss": "^4.3.0"
  }
}
